{
  "id": "filesystem-tools",
  "name": "filesystem-tools",
  "version": "1.0.0",
  "description": "Workspace-bounded filesystem operations through MCP.",
  "author": "allo-official",
  "type": "mcp",
  "command": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-filesystem", "$ALLO_WORKSPACE_PATH"],
    "env": {}
  },
  "tools": [],
  "permissions": ["filesystem-read", "filesystem-write", "workspace-only"],
  "required_env": [],
  "optional_env": [],
  "credentials": [],
  "homepage": "https://github.com/modelcontextprotocol/servers",
  "notes": "ALLO_WORKSPACE_PATH is injected by Allo at runtime. Do not point this plugin at a home directory or filesystem root.",
  "source": "marketplace"
}
